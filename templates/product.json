{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "trust_block": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'ma-product-trust', product: product, section_id: section.id %}"
          }
        },
        "description": {
          "type": "description"
        },
        "collapsible-material": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Material & Details",
            "icon": "star",
            "content": "<p>Sorgfältig ausgewählte Materialien für langanhaltende Freude – je nach Modell vergoldete Legierungen, Edelstahl, Süßwasserperlen oder Kristalle. Die genaue Ausführung findest du in der Beschreibung oben.</p>",
            "page": ""
          }
        },
        "collapsible-shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Versand & Lieferung",
            "icon": "truck",
            "content": "<p>Jede Bestellung wird sorgfältig geprüft, liebevoll von Hand verpackt und mit Sendungsverfolgung verschickt. Die Lieferzeit beträgt in der Regel 1–3 Wochen. Kostenloser Versand ab einem Bestellwert von CHF 100.</p>",
            "page": ""
          }
        },
        "collapsible-returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Rückgabe",
            "icon": "return",
            "content": "<p>14 Tage Rückgaberecht für ungetragene Artikel. Melde dich einfach über unser Kontaktformular – wir helfen dir gerne.</p>",
            "page": ""
          }
        },
        "collapsible-care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Pflegehinweise",
            "icon": "heart",
            "content": "<p>Schmuck vor Wasser, Parfum und Cremes ablegen, trocken aufbewahren und mit einem weichen Tuch reinigen. Ausführliche Tipps findest du auf unserer Seite „Schmuckpflege“.</p>",
            "page": ""
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Teilen"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "trust_block",
        "description",
        "collapsible-material",
        "collapsible-shipping",
        "collapsible-returns",
        "collapsible-care",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": false,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "usps": {
      "type": "multicolumn",
      "blocks": {
        "u1": {
          "type": "column",
          "settings": {
            "title": "Kostenloser Versand",
            "text": "<p>Gratis Lieferung ab einem Bestellwert von CHF 100.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "u2": {
          "type": "column",
          "settings": {
            "title": "14 Tage Rückgabe",
            "text": "<p>Unkomplizierte Rückgabe ungetragener Artikel.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "u3": {
          "type": "column",
          "settings": {
            "title": "Liebevoll verpackt",
            "text": "<p>Jedes Stück kommt in edler Geschenkverpackung.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": ["u1", "u2", "u3"],
      "settings": {
        "title": "",
        "heading_size": "h2",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "center",
        "background_style": "none",
        "button_label": "",
        "button_link": "",
        "swipe_on_mobile": false,
        "color_scheme": "scheme-5",
        "columns_mobile": "1",
        "padding_top": 28,
        "padding_bottom": 28
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Das könnte dir auch gefallen",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "portrait",
        "show_secondary_image": false,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 40,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "usps",
    "related-products"
  ]
}
