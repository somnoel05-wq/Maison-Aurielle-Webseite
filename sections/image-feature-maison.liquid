{{ 'section-image-feature-maison.css' | asset_url | stylesheet_tag }}

<div class="image-feature color-{{ section.settings.color_scheme }} gradient">
  <div class="image-feature__grid page-width image-feature__grid--{{ section.settings.image_position }}">
    <div class="image-feature__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 50vw, 100vw', widths: '600, 900, 1200, 1600', class: 'image-feature__img'
        }}
      {%- elsif section.settings.image_asset != blank -%}
        <img src="{{ section.settings.image_asset | asset_url }}" alt="" class="image-feature__img" loading="lazy">
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'image-feature__img placeholder' }}
      {%- endif -%}
    </div>

    <div class="image-feature__content">
      {%- if section.settings.overline != blank -%}
        <p class="image-feature__overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="image-feature__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <span class="image-feature__rule" aria-hidden="true"></span>
      {%- if section.settings.text != blank -%}
        <div class="image-feature__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="button button--primary image-feature__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bild & Text Maison",
  "tag": "section",
  "class": "section section-image-feature",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Bild aus Theme-Assets (Dateiname)",
      "info": "z. B. about-portrait.png – genutzt, wenn kein Bild oben gewählt ist."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Überzeile",
      "default": "Die Maison"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Schmuck mit Seele"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    }
  ],
  "presets": [
    { "name": "Bild & Text Maison" }
  ]
}
{% endschema %}
