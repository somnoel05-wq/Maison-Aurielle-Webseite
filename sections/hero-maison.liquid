{{ 'section-hero-maison.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_video = false
  assign has_picker = false
  assign has_asset = false
  if section.settings.video_asset != blank
    assign has_video = true
  endif
  if section.settings.background_image != blank
    assign has_picker = true
  elsif section.settings.image_asset != blank
    assign has_asset = true
  endif
-%}

<div class="hero-maison hero-maison--{{ section.settings.height }} hero-maison--{{ section.settings.text_align }} color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-maison__media">
    {%- if has_video -%}
      <video
        class="hero-maison__video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
        tabindex="-1"
        disablepictureinpicture
        {%- if section.settings.background_image != blank %}
          poster="{{ section.settings.background_image | image_url: width: 2000 }}"
        {%- elsif section.settings.image_asset != blank %}
          poster="{{ section.settings.image_asset | asset_url }}"
        {%- endif %}
      >
        <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
      </video>
    {%- elsif has_picker -%}
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000, 3000',
          class: 'hero-maison__image'
      }}
    {%- elsif has_asset -%}
      <img
        src="{{ section.settings.image_asset | asset_url }}"
        alt=""
        class="hero-maison__image"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <span class="hero-maison__scrim hero-maison__scrim--{{ section.settings.text_align }}" aria-hidden="true"></span>
  </div>

  <div class="hero-maison__inner page-width">
    {%- if section.settings.overline != blank -%}
      <p class="hero-maison__overline">{{ section.settings.overline }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-maison__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="hero-maison__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
      <div class="hero-maison__buttons">
        {%- if section.settings.button_label_1 != blank -%}
          <a href="{{ section.settings.button_link_1 | default: '#' }}" class="button button--primary hero-maison__btn">
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 | default: '#' }}" class="button button--secondary hero-maison__btn">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Maison",
  "tag": "section",
  "class": "section section-hero-maison",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Textausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Überzeile",
      "default": "Feiner Schmuck · Handverlesen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Maison Aurielle"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Untertitel",
      "default": "<p>Zeitlose Stücke, gefertigt für Momente, die bleiben.</p>"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 – Text",
      "default": "Kollektion entdecken"
    },
    { "type": "url", "id": "button_link_1", "label": "Button 1 – Link" },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 – Text",
      "default": "Uhren ansehen"
    },
    { "type": "url", "id": "button_link_2", "label": "Button 2 – Link" },
    { "type": "image_picker", "id": "background_image", "label": "Hintergrundbild" },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Hintergrundbild aus Theme-Assets (Dateiname)",
      "info": "z. B. hero-heart-pendant.png – genutzt, wenn kein Bild oben gewählt ist. Dient auch als Vorschaubild (Poster) für das Video."
    },
    {
      "type": "text",
      "id": "video_asset",
      "label": "Hintergrund-Video aus Theme-Assets (Dateiname)",
      "info": "z. B. hero.mp4 – spielt automatisch, stumm und in Schleife. Überschreibt das Hintergrundbild."
    },
    {
      "type": "select",
      "id": "height",
      "label": "Höhe",
      "options": [
        { "value": "medium", "label": "Mittel" },
        { "value": "large", "label": "Groß" },
        { "value": "full", "label": "Bildschirmhoch" }
      ],
      "default": "large"
    }
  ],
  "presets": [{ "name": "Hero Maison" }]
}
{% endschema %}
