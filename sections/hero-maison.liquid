{{ 'section-hero-maison.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_image = false
  if section.settings.background_image != blank
    assign has_image = true
  endif
-%}

<div class="hero-maison hero-maison--{{ section.settings.height }} color-{{ section.settings.color_scheme }} gradient{% if has_image %} hero-maison--image{% endif %}">
  {%- if has_image -%}
    <div class="hero-maison__media">
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000, 3000',
          class: 'hero-maison__image'
      }}
      <span class="hero-maison__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></span>
    </div>
  {%- endif -%}

  <div class="hero-maison__inner page-width">
    {%- if section.settings.overline != blank -%}
      <p class="hero-maison__overline">{{ section.settings.overline }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-maison__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    <span class="hero-maison__rule" aria-hidden="true"></span>

    {%- if section.settings.subheading != blank -%}
      <div class="hero-maison__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
      <div class="hero-maison__buttons">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            href="{{ section.settings.button_link_1 | default: '#' }}"
            class="button button--primary hero-maison__button"
          >
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a
            href="{{ section.settings.button_link_2 | default: '#' }}"
            class="button button--secondary hero-maison__button"
          >
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Maison",
  "tag": "section",
  "class": "section section-hero-maison",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Überzeile",
      "default": "Feiner Schmuck · Handverlesen aus der Schweiz"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Maison Aurielle"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Untertitel",
      "default": "<p>Zeitlose Stücke, gefertigt für Momente, die bleiben. Entdecke Schmuck und Uhren, die deine Geschichte erzählen.</p>"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 – Text",
      "default": "Kollektion entdecken"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 – Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 – Text",
      "default": "Uhren ansehen"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 – Link"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Hintergrundbild (optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Bild-Abdunklung",
      "default": 35
    },
    {
      "type": "select",
      "id": "height",
      "label": "Höhe",
      "options": [
        { "value": "medium", "label": "Mittel" },
        { "value": "large", "label": "Groß" },
        { "value": "full", "label": "Bildschirmhoch" }
      ],
      "default": "large"
    }
  ],
  "presets": [
    {
      "name": "Hero Maison"
    }
  ]
}
{% endschema %}
